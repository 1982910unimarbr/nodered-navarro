    {
        "id": "2f54dd27b91c91cb",
        "type": "function",
        "z": "b6ec9e4fcfb73207",
        "name": "Validar temperatura",
        "func": "let roomState = 0\nlet ligarVentilador = false\nif (msg.payload) {\n    let dados = JSON.parse(msg.payload);\n    let temperatura = parseFloat(dados.temperatura)\n    if (temperatura >= 50) {\n        roomState = 2\n    }\n    else {\n        if (temperatura > 25) {\n            roomState = 1\n            ligarVentilador = true\n        }else{\n            roomState = 0\n            ligarVentilador = false\n        }\n    }\n\n    msg.roomState  = roomState;\n    msg.payload = JSON.stringify({...dados, roomState, ligarVentilador, temperatura});\n}\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 570,
        "y": 60,
        "wires": [
            [
                "83610fd237729bfe"
            ]
        ]
    },
