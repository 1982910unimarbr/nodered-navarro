    {
        "id": "formatar_dashboard",
        "type": "function",
        "z": "803e46c0722e018f",
        "name": "Formatar Dashboard",
        "func": "let dados = JSON.parse(msg.payload);\n\n// saída 1 -> temperatura\nlet tempMsg = {\n    payload: dados.temperatura\n};\n\n// saída 2 -> estado\nlet estadoMsg = {\n    payload: dados.roomState\n};\n\n// saída 3 -> alerta texto\nlet alertaMsg = {\n    payload: dados.roomState === 2 ? \"🔥 INCÊNDIO DETECTADO\" : \"OK\"\n};\n\nreturn [tempMsg, estadoMsg, alertaMsg];",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
